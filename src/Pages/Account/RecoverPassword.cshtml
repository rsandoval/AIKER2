@page
@model AIKER2.Pages.Account.RecoverPasswordModel
@{
    Layout = "/Pages/Shared/_Layout_Login.cshtml";
}

<section>
    <div class="container d-flex flex-column">
        <div class="row align-items-center justify-content-center min-vh-100">
            <div class="col-md-6 col-lg-5 col-xl-5 py-6 py-md-0">
                <div class="card shadow zindex-100 mb-0">
                    <div class="card-body px-md-5 py-5">
                        @if (Model.Sent)
                        {
                            <div class="mb-4">
                                <h6 class="h3">Correo enviado</h6>
                            </div>
                            <p>
                                Revisa tu bandeja de entrada. Si el correo existe en el sistema,
                                recibirás el enlace en breve.
                            </p>
                            <div class="mt-4">
                                <a href="/Account/Login" class="small text-muted">
                                    ← Volver al inicio de sesión
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="mb-5">
                                <h6 class="h3">Recuperar contraseña</h6>
                                <p class="text-muted mt-2">
                                    Ingresa tu e-mail y te enviaremos un enlace para restablecer tu contraseña.
                                </p>
                                @if (Model.ErrorMessage is not null)
                                {
                                    <div class="alert alert-danger mt-3 mb-0">@Model.ErrorMessage</div>
                                }
                            </div>
                            <span class="clearfix"></span>
                            <form method="post">
                                <div class="form-group">
                                    <label class="form-control-label">E-mail</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text"><i data-feather="user"></i></span>
                                        </div>
                                        <input asp-for="Email" type="email" placeholder="Email"
                                               class="form-control form-control-emphasized" autocomplete="email">
                                    </div>
                                </div>
                                <div class="mt-4">
                                    <button type="submit" class="btn btn-block btn-primary">Enviar enlace</button>
                                </div>
                            </form>
                            <div class="mt-4">
                                <a href="/Account/Login" class="small text-muted">
                                    ← Volver al inicio de sesión
                                </a>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
