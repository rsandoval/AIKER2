@page
@model IndexModel
@{
    Layout = "_Layout_Landed";
    ViewData["Title"] = "AIKER by R:Solver | Mejorando el conocimiento humano con Inteligencia Artificial";
}

<!-- Main content -->
<section class="slice py-7">
    <div class="container">
        <div class="row row-grid align-items-center">
            <div class="col-12 col-md-5 col-lg-6 order-md-2 text-center">
                <!-- Image -->
                <figure class="w-100">
                    <img alt="Image placeholder" src="images/AIKER-logo-extra.png" class="img-fluid mw-md-120">
                </figure>
            </div>
            <div class="col-12 col-md-7 col-lg-6 order-md-1 pr-md-5">
                <!-- Heading -->
                <h2 class="display-4 text-center text-md-left mb-3">
                    Mejorando el <strong class="text-primary">conocimiento humano</strong> con
                    <strong>inteligencia artificial</strong>
                </h2>
                <!-- Text -->
                <p class="lead text-center text-md-left text-muted">
                    AIKER utiliza inteligencia artificial, especialmente NLU, para procesar y resumir fuentes de información diversas y confiables,
                    permitiendo la revisión, evaluación, y mejor entendimiento argumentativo del conocimiento escrito.
                </p>
                <!-- Buttons -->
                <div class="text-center text-md-left mt-5">
                    <a href="/TakeTest" class="btn btn-primary btn-icon">
                        <span class="btn-inner--text">Rendir prueba</span>
                        <span class="btn-inner--icon"><i data-feather="chevron-right"></i></span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="slice slice-lg pt-lg-6 pb-0 pb-lg-6 bg-section-secondary">
    <div class="container">
        <!-- Title -->
        <!-- Section title -->
        <div class="row mb-5 justify-content-center text-center">
            <div class="col-lg-6">
                <span class="badge badge-soft-success badge-pill badge-lg">
                    <a name="what"></a>Qué hace
                </span>
                <h2 class="mt-4">Inteligencia Artificial para mejorar la calidad del aprendizaje</h2>
                <div class="mt-2">
                    <p class="lead lh-180">AIKER tiene la capacidad de entender y resumir documentación especializada, así como evaluar y entregar retroalimentación sobre respuestas de argumentación y razonamiento, facilitando el proceso de preparación y rendición de evaluaciones.</p>
                </div>
            </div>
        </div>
        <!-- Card -->
        <div class="row mt-5">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body pb-5">
                        <div class="pt-4 pb-5">
                            <img src="assets/img/svg/illustrations/illustration-8.svg" class="img-fluid img-center" style="height: 150px;" alt="Illustration" />
                        </div>
                        <h5 class="h4 lh-130 mb-3">Conocimiento documental</h5>
                        <p class="text-muted mb-0">Gestión, análisis, y entendimiento de múltiples referencias de información validada.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body pb-5">
                        <div class="pt-4 pb-5">
                            <img src="assets/img/svg/illustrations/illustration-4.svg" class="img-fluid img-center" style="height: 150px;" alt="Illustration" />
                        </div>
                        <h5 class="h4 lh-130 mb-3">Asistente de aprendizaje</h5>
                        <p class="text-muted mb-0">Ensayo y validación de respuestas argumentadas, reforzando el correcto aprendizaje.</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card">
                    <div class="card-body pb-5">
                        <div class="pt-4 pb-5">
                            <img src="assets/img/svg/illustrations/illustration-14.svg" class="img-fluid img-center" style="height: 150px;" alt="Illustration" />
                        </div>
                        <h5 class="h4 lh-130 mb-3">Revisión y evaluación</h5>
                        <p class="text-muted mb-0">Gestión integrada de evaluaciones y resultados con automatización avanzada.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="slice slice-lg">
    <div class="container">
        <div class="row">
            <div class="col-lg-6">
                <span class="badge badge-primary badge-pill">Los números</span>
                <h5 class="lh-180 mt-4 mb-6">AIKER se ha estado usando en diferentes cursos para mejorar el conocimiento.</h5>
            </div>
        </div>
        <!-- Features -->
        <div class="row mx-lg-n4">
            <!-- Features - Col 1 -->
            <div class="col-lg-4 col-md-6 px-lg-4">
                <div class="card shadow-none">
                    <div class="p-3 d-flex">
                        <div>
                            <div class="icon icon-shape rounded-circle bg-warning text-white mr-4">
                                <i data-feather="check"></i>
                            </div>
                        </div>
                        <div>
                            <span class="h6">+10.000 respuestas</span>
                            <p class="text-sm text-muted mb-0">
                                Respuestas rendidas por alumnos y revisadas por AIKER.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 px-lg-4">
                <div class="card shadow-none">
                    <div class="p-3 d-flex">
                        <div>
                            <div class="icon icon-shape rounded-circle bg-primary text-white mr-4">
                                <i data-feather="check"></i>
                            </div>
                        </div>
                        <div>
                            <span class="h6">+1.000 Estudiantes</span>
                            <p class="text-sm text-muted mb-0">
                                Estudiantes que han rendido pruebas.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4 col-md-6 px-lg-4">
                <div class="card shadow-none">
                    <div class="p-3 d-flex">
                        <div>
                            <div class="icon icon-shape rounded-circle bg-success text-white mr-4">
                                <i data-feather="check"></i>
                            </div>
                        </div>
                        <div>
                            <span class="h6">90% autorevisión</span>
                            <p class="text-sm text-muted mb-0">
                                Evaluaciones y feedback generado automáticamente.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


<section class="slice slice-lg bg-section-dark pt-5 pt-lg-8">
    <!-- SVG separator -->
    <div class="shape-container shape-line shape-position-top shape-orientation-inverse">
        <svg width="2560px" height="100px" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" preserveAspectRatio="none" x="0px" y="0px" viewBox="0 0 2560 100" style="enable-background:new 0 0 2560 100;" xml:space="preserve" class="">
        <polygon points="2560 0 2560 100 0 100"></polygon>
            </svg>
    </div>
    <!-- Container -->
    <div class="container position-relative zindex-100">
        <div class="col">
            <div class="row justify-content-center">
                <div class="col-md-10 text-center">
                    <div class="mt-4 mb-6">
                        <h2 class="h1 text-white">
                            ¿Te interesa conocer más de AIKER?
                        </h2>
                        <!-- Play button -->
                        <a href="/demo" class="btn btn-primary btn-icon mt-4">Ver una demostración</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="slice pt-0">
    <div class="container position-relative zindex-100">
        <div class="row">
            <div class="col-l-4 col-sm-6 mt-n7">
                <div class="card">
                    <div class="d-flex p-3">
                        <div>
                            <span class="badge badge-success badge-pill">Personas</span>
                        </div>
                        <div class="pl-4">
                            <h5 class="lh-130">AIKER para estudiantes</h5>
                            <p class="text-muted mb-0">
                                Aprovecha un <i>coach</i> automatizado reforzando el aprendizaje.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-l-4 col-sm-6 mt-sm-n7">
                <div class="card">
                    <div class="d-flex p-3">
                        <div>
                            <span class="badge badge-info badge-pill">Instituciones</span>
                        </div>
                        <div class="pl-4">
                            <h5 class="lh-130">AIKER para instituciones</h5>
                            <p class="text-muted mb-0">
                                Potentes características que facilitan la gestión académica.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="card shadow-lg border-0" style="max-width: 100%;">
            <div class="card-body px-5 py-5 text-center text-md-left">
                <div class="row align-items-center">
                    <div class="col-md-6">
                        <a name="who"><h5 class="mb-2">Resolvamos tus necesidades, ya sea como institución o estudiante.</h5></a>
                        <p class="mb-0">Escríbenos a:</p>
                    </div>
                    <div class="col-12 col-md-6 mt-4 mt-md-0 text-md-right">
                        <a href="#who" class="btn btn-primary btn-icon rounded-pill">
                            <span class="btn-inner--icon">
                                <i data-feather="mail"></i>
                            </span>
                            <span class="btn-inner--text">comercial@aiker.ai</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</section>
